# kn0 configuration — copy to .env and adjust as needed

DATABASE_URL=sqlite:///./kn0.db
UPLOAD_DIR=./uploads
SPACY_MODEL=en_core_web_sm

# Entity resolution thresholds [0–1]
MERGE_THRESHOLD=0.85
REVIEW_THRESHOLD=0.65

# Confidence scoring
MIN_CONFIDENCE_DISPLAY=0.3
SOURCE_RELIABILITY_DEFAULT=0.5

# API server
API_HOST=127.0.0.1
API_PORT=8000

# LLM backend — used for entity extraction (--backend llm) and GraphRAG
# Provider: lm_studio | ollama | openai | anthropic
LLM_PROVIDER=lm_studio
LLM_MODEL=local-model
# LM Studio default:
LLM_BASE_URL=http://localhost:1234/v1
# Ollama: LLM_BASE_URL=http://localhost:11434/v1  LLM_MODEL=llama3.2
# OpenAI: LLM_BASE_URL=https://api.openai.com/v1  LLM_MODEL=gpt-4o-mini
LLM_API_KEY=lm-studio
LLM_TEMPERATURE=0.0
LLM_TIMEOUT=60.0
